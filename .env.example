PHP_EXTENSIONS=amqp apcu ast bcmath bz2 calendar exif gd gettext gmp igbinary imagick imap intl ldap mbstring memcached mongodb mysqli opcache pcntl pdo_mysql pdo_pgsql pgsql redis soap sockets swoole uuid xdebug xsl yaml zip
PHP_PECL_EXTENSIONS=
NODE_VERSION=20
MYSQL_VERSION=8.0
MARIADB_VERSION=11.4
POSTGRES_VERSION=16
MONGO_VERSION=7
RABBITMQ_VERSION=3.13
SOLR_VERSION=9
MINIO_VERSION=latest

MYSQL_DATABASE=devstack
MYSQL_USER=devstack
MYSQL_PASSWORD=devstack
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

MARIADB_DATABASE=devstack
MARIADB_USER=devstack
MARIADB_PASSWORD=devstack
MARIADB_ROOT_PASSWORD=root
MARIADB_PORT=3307

POSTGRES_DB=devstack
POSTGRES_USER=devstack
POSTGRES_PASSWORD=devstack
POSTGRES_PORT=5432

MONGO_INITDB_ROOT_USERNAME=devstack
MONGO_INITDB_ROOT_PASSWORD=devstack
MONGO_PORT=27017

REDIS_PORT=6379
MEMCACHED_PORT=11211
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025
ADMINER_PORT=8081
PHPMYADMIN_PORT=8082
PGADMIN_PORT=8083
REDIS_COMMANDER_PORT=8084
MONGO_EXPRESS_PORT=8085
RABBITMQ_AMQP_PORT=5672
