COMPOSE_PROJECT_NAME=devstack

DEFAULT_PROJECT=default
DEVSTACK_DOMAIN=localhost
DEVSTACK_RUNTIME_MODE=auto

APP_PORT=80
APP_HOST=0.0.0.0
INTRANET_PORT=8079

PHP_VERSION=8.3
